{
  "name": "scribo",
  "version": "1.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "expo start -c",
    "android": "expo start --android",
    "android:run": "expo run:android",
    "android:run:device": "expo run:android --device",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "lint": "eslint src app",
    "lint:fix": "eslint src app --fix",
    "lint:all": "eslint src app __tests__ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:all": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\" \"__tests__/**/*.{ts,tsx}\"",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "doctor": "expo doctor",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@reduxjs/toolkit": "^2.5.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-asset": "~12.0.9",
    "expo-font": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@eslint/js": "^9.0.0",
    "@testing-library/react-native": "^12.1.2",
    "@types/jest": "~29.5.14",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
